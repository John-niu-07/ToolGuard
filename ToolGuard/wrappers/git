#!/usr/bin/env python3
"""
ToolGuard Wrapper for git CLI

监控 git 的危险操作：push, commit, merge, rebase, reset, clean 等
"""

import subprocess
import sys
import json
import http.client
import os
from pathlib import Path

TOOLGUARD_HOST = '127.0.0.1'
TOOLGUARD_PORT = 8767
TIMEOUT = 5
REAL_GIT = '/usr/bin/git'

def check_toolguard():
    """检查 ToolGuard 是否允许执行"""
    args = sys.argv[1:]
    command = ' '.join(['git'] + args)
    
    # 判断风险等级
    risky_commands = ['push', 'commit', 'merge', 'rebase', 'reset', 'clean', 'filter-branch', 'gc']
    write_commands = ['push', 'commit', 'merge', 'rebase', 'reset', 'clean']
    
    if not args or args[0] not in risky_commands:
        return True  # 安全命令，直接放行
    
    risk_level = 'high' if args[0] in write_commands else 'medium'
    reason = f'git {args[0]}: 可能修改版本历史或推送代码'
    
    if args[0] == 'push':
        risk_level = 'critical'
        reason = 'git push: 推送代码到远程仓库，可能泄露敏感信息'
    elif args[0] in ['reset', 'clean']:
        risk_level = 'critical'
        reason = f'git {args[0]}: 可能丢失未提交的更改'
    
    try:
        conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
        conn.request('POST', '/check', json.dumps({
            'tool_name': 'git',
            'action': args[0] if args else '*',
            'parameters': {
                'command': command,
                'args': args,
                'cwd': os.getcwd()
            }
        }), {'Content-Type': 'application/json'})
        
        response = conn.getresponse()
        data = json.loads(response.read().decode())
        conn.close()
        
        if data.get('need_confirmation'):
            print(f"\n🛡️ ToolGuard 拦截：{command}")
            print(f"   原因：{data.get('reason', reason)}")
            print(f"   风险等级：{data.get('risk_level', risk_level)}")
            print(f"   确认 ID: {data.get('confirmation_id')}")
            print(f"\n请在 Web 界面确认：http://{TOOLGUARD_HOST}:{TOOLGUARD_PORT}")
            
            import time
            start_time = time.time()
            timeout = 300
            
            while time.time() - start_time < timeout:
                try:
                    conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
                    conf_id = data.get('confirmation_id')
                    conn.request('GET', f'/api/confirmation/{conf_id}')
                    response = conn.getresponse()
                    status_data = json.loads(response.read().decode())
                    conn.close()
                    
                    status = status_data.get('status')
                    if status == 'approved':
                        print("✅ 用户已允许，继续执行...\n")
                        return True
                    elif status == 'denied':
                        print("❌ 用户已拒绝，终止执行")
                        sys.exit(1)
                    elif status == 'expired':
                        print("⏰ 确认已超时，终止执行")
                        sys.exit(1)
                except Exception:
                    pass
                time.sleep(2)
            
            print("⏰ 等待确认超时，终止执行")
            sys.exit(1)
        
        return True
        
    except Exception as e:
        print(f"⚠️ ToolGuard 检查失败：{e}，继续执行...")
        return True

def main():
    check_toolguard()
    
    git_path = REAL_GIT
    if not Path(git_path).exists():
        result = subprocess.run(['which', 'git'], capture_output=True, text=True)
        if result.returncode == 0:
            git_path = result.stdout.strip()
    
    try:
        result = subprocess.run([git_path] + sys.argv[1:])
        sys.exit(result.returncode)
    except FileNotFoundError:
        print(f"❌ 找不到 git: {git_path}")
        sys.exit(1)
    except KeyboardInterrupt:
        print("\n⚠️ 用户中断")
        sys.exit(130)

if __name__ == '__main__':
    main()
