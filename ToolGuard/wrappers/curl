#!/usr/bin/env python3
"""
ToolGuard Wrapper for curl CLI

监控 curl 的网络请求，特别是 POST 请求和敏感 URL
"""

import subprocess
import sys
import json
import http.client
import os
from pathlib import Path

TOOLGUARD_HOST = '127.0.0.1'
TOOLGUARD_PORT = 8767
TIMEOUT = 5
REAL_CURL = '/usr/bin/curl'

def check_toolguard():
    """检查 ToolGuard 是否允许执行"""
    args = sys.argv[1:]
    command = ' '.join(['curl'] + args)
    
    # 判断风险等级
    risk_level = 'low'
    reason = 'curl 网络请求'
    
    # 检查是否有敏感操作
    sensitive_patterns = ['-d', '--data', '--data-binary', '--data-raw', '-X POST', '-X PUT', '-X DELETE']
    sensitive_urls = ['password', 'token', 'key', 'secret', 'api', 'auth', 'login']
    
    has_data = any(p in args for p in sensitive_patterns)
    has_sensitive_url = any(s in command.lower() for s in sensitive_urls)
    
    if has_data:
        risk_level = 'medium'
        reason = 'curl 发送数据请求，可能泄露敏感信息'
    
    if has_sensitive_url and has_data:
        risk_level = 'high'
        reason = 'curl 向敏感 URL 发送数据'
    
    # GET 请求通常安全
    if not has_data and '-X' not in args:
        return True
    
    try:
        conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
        conn.request('POST', '/check', json.dumps({
            'tool_name': 'curl',
            'action': 'request',
            'parameters': {
                'command': command,
                'args': args,
                'has_data': has_data,
                'sensitive_url': has_sensitive_url
            }
        }), {'Content-Type': 'application/json'})
        
        response = conn.getresponse()
        data = json.loads(response.read().decode())
        conn.close()
        
        if data.get('need_confirmation'):
            print(f"\n🛡️ ToolGuard 拦截：{command}")
            print(f"   原因：{data.get('reason', reason)}")
            print(f"   风险等级：{data.get('risk_level', risk_level)}")
            print(f"   确认 ID: {data.get('confirmation_id')}")
            print(f"\n请在 Web 界面确认：http://{TOOLGUARD_HOST}:{TOOLGUARD_PORT}")
            
            import time
            start_time = time.time()
            timeout = 300
            
            while time.time() - start_time < timeout:
                try:
                    conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
                    conf_id = data.get('confirmation_id')
                    conn.request('GET', f'/api/confirmation/{conf_id}')
                    response = conn.getresponse()
                    status_data = json.loads(response.read().decode())
                    conn.close()
                    
                    status = status_data.get('status')
                    if status == 'approved':
                        print("✅ 用户已允许，继续执行...\n")
                        return True
                    elif status == 'denied':
                        print("❌ 用户已拒绝，终止执行")
                        sys.exit(1)
                    elif status == 'expired':
                        print("⏰ 确认已超时，终止执行")
                        sys.exit(1)
                except Exception:
                    pass
                time.sleep(2)
            
            print("⏰ 等待确认超时，终止执行")
            sys.exit(1)
        
        return True
        
    except Exception as e:
        print(f"⚠️ ToolGuard 检查失败：{e}，继续执行...")
        return True

def main():
    check_toolguard()
    
    curl_path = REAL_CURL
    if not Path(curl_path).exists():
        result = subprocess.run(['which', 'curl'], capture_output=True, text=True)
        if result.returncode == 0:
            curl_path = result.stdout.strip()
    
    try:
        result = subprocess.run([curl_path] + sys.argv[1:])
        sys.exit(result.returncode)
    except FileNotFoundError:
        print(f"❌ 找不到 curl: {curl_path}")
        sys.exit(1)
    except KeyboardInterrupt:
        print("\n⚠️ 用户中断")
        sys.exit(130)

if __name__ == '__main__':
    main()
