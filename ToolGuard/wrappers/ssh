#!/usr/bin/env python3
"""
ToolGuard Wrapper for ssh CLI

监控 SSH 连接，防止未授权的远程访问
"""

import subprocess
import sys
import json
import http.client
import os
from pathlib import Path

TOOLGUARD_HOST = '127.0.0.1'
TOOLGUARD_PORT = 8767
TIMEOUT = 5
REAL_SSH = '/usr/bin/ssh'

def check_toolguard():
    """检查 ToolGuard 是否允许执行"""
    args = sys.argv[1:]
    command = ' '.join(['ssh'] + args)
    
    # 提取主机名
    host = None
    for arg in args:
        if not arg.startswith('-') and '@' in arg:
            host = arg.split('@')[-1]
            break
        elif not arg.startswith('-'):
            host = arg
            break
    
    risk_level = 'high'
    reason = f'SSH 连接到 {host or "未知主机"}，可能访问远程系统'
    
    try:
        conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
        conn.request('POST', '/check', json.dumps({
            'tool_name': 'ssh',
            'action': 'connect',
            'parameters': {
                'command': command,
                'args': args,
                'host': host
            }
        }), {'Content-Type': 'application/json'})
        
        response = conn.getresponse()
        data = json.loads(response.read().decode())
        conn.close()
        
        if data.get('need_confirmation'):
            print(f"\n🛡️ ToolGuard 拦截：{command}")
            print(f"   原因：{data.get('reason', reason)}")
            print(f"   风险等级：{data.get('risk_level', risk_level)}")
            print(f"   确认 ID: {data.get('confirmation_id')}")
            print(f"\n请在 Web 界面确认：http://{TOOLGUARD_HOST}:{TOOLGUARD_PORT}")
            
            import time
            start_time = time.time()
            timeout = 300
            
            while time.time() - start_time < timeout:
                try:
                    conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
                    conf_id = data.get('confirmation_id')
                    conn.request('GET', f'/api/confirmation/{conf_id}')
                    response = conn.getresponse()
                    status_data = json.loads(response.read().decode())
                    conn.close()
                    
                    status = status_data.get('status')
                    if status == 'approved':
                        print("✅ 用户已允许，继续执行...\n")
                        return True
                    elif status == 'denied':
                        print("❌ 用户已拒绝，终止执行")
                        sys.exit(1)
                    elif status == 'expired':
                        print("⏰ 确认已超时，终止执行")
                        sys.exit(1)
                except Exception:
                    pass
                time.sleep(2)
            
            print("⏰ 等待确认超时，终止执行")
            sys.exit(1)
        
        return True
        
    except Exception as e:
        print(f"⚠️ ToolGuard 检查失败：{e}，继续执行...")
        return True

def main():
    check_toolguard()
    
    ssh_path = REAL_SSH
    if not Path(ssh_path).exists():
        result = subprocess.run(['which', 'ssh'], capture_output=True, text=True)
        if result.returncode == 0:
            ssh_path = result.stdout.strip()
    
    try:
        result = subprocess.run([ssh_path] + sys.argv[1:])
        sys.exit(result.returncode)
    except FileNotFoundError:
        print(f"❌ 找不到 ssh: {ssh_path}")
        sys.exit(1)
    except KeyboardInterrupt:
        print("\n⚠️ 用户中断")
        sys.exit(130)

if __name__ == '__main__':
    main()
