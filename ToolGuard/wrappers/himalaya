#!/usr/bin/env python3
"""
ToolGuard Wrapper for himalaya CLI

在调用真实的 himalaya 命令前，先通过 ToolGuard 检查
"""

import subprocess
import sys
import json
import http.client
import os
from pathlib import Path

# ToolGuard 服务配置
TOOLGUARD_HOST = '127.0.0.1'
TOOLGUARD_PORT = 8767
TIMEOUT = 5

# 真实的 himalaya 路径
REAL_HIMALAYA = '/usr/local/bin/himalaya.real'

def check_toolguard():
    """检查 ToolGuard 是否允许执行"""
    # 获取命令参数
    args = sys.argv[1:]
    command = ' '.join(['himalaya'] + args)
    
    # 判断风险等级
    risk_level = 'medium'
    reason = '调用 himalaya CLI 工具'
    
    # 如果是发送相关命令，提高风险等级
    send_keywords = ['send', 'write', 'reply', 'forward']
    if any(kw in args for kw in send_keywords):
        risk_level = 'high'
        reason = '发送邮件，可能发送未授权内容'
    
    try:
        conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
        conn.request('POST', '/check', json.dumps({
            'tool_name': 'himalaya',
            'action': ' '.join(args[:2]) if args else '*',
            'parameters': {
                'command': command,
                'args': args
            }
        }), {'Content-Type': 'application/json'})
        
        response = conn.getresponse()
        data = json.loads(response.read().decode())
        conn.close()
        
        if data.get('need_confirmation'):
            print(f"\n🛡️ ToolGuard 拦截：{command}")
            print(f"   原因：{data.get('reason', reason)}")
            print(f"   风险等级：{data.get('risk_level', risk_level)}")
            print(f"   确认 ID: {data.get('confirmation_id')}")
            print(f"\n请在 Web 界面确认：http://{TOOLGUARD_HOST}:{TOOLGUARD_PORT}")
            print(f"或等待超时（默认 5 分钟）\n")
            
            # 轮询确认状态
            import time
            start_time = time.time()
            timeout = 300  # 5 分钟
            
            while time.time() - start_time < timeout:
                try:
                    conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
                    conf_id = data.get('confirmation_id')
                    conn.request('GET', f'/api/confirmation/{conf_id}')
                    response = conn.getresponse()
                    status_data = json.loads(response.read().decode())
                    conn.close()
                    
                    status = status_data.get('status')
                    if status == 'approved':
                        print("✅ 用户已允许，继续执行...\n")
                        return True
                    elif status == 'denied':
                        print("❌ 用户已拒绝，终止执行")
                        sys.exit(1)
                    elif status == 'expired':
                        print("⏰ 确认已超时，终止执行")
                        sys.exit(1)
                
                except Exception as e:
                    pass
                
                time.sleep(2)
            
            print("⏰ 等待确认超时，终止执行")
            sys.exit(1)
        
        return True
        
    except Exception as e:
        # Fail-open: ToolGuard 不可用时放行
        print(f"⚠️ ToolGuard 检查失败：{e}，继续执行...")
        return True

def main():
    # 检查 ToolGuard
    check_toolguard()
    
    # 找到真实的 himalaya
    himalaya_path = REAL_HIMALAYA
    if not Path(himalaya_path).exists():
        # 尝试在 PATH 中找
        result = subprocess.run(['which', 'himalaya'], capture_output=True, text=True)
        paths = [p for p in os.environ.get('PATH', '').split(':') if '/ToolGuard' not in p]
        for path_dir in paths:
            test_path = Path(path_dir) / 'himalaya'
            if test_path.exists() and str(test_path) != Path(__file__).resolve():
                himalaya_path = str(test_path)
                break
    
    # 执行真实的 himalaya
    try:
        result = subprocess.run([himalaya_path] + sys.argv[1:])
        sys.exit(result.returncode)
    except FileNotFoundError:
        print(f"❌ 找不到 himalaya: {himalaya_path}")
        sys.exit(1)
    except KeyboardInterrupt:
        print("\n⚠️ 用户中断")
        sys.exit(130)

if __name__ == '__main__':
    main()
