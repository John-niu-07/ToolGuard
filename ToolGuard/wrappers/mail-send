#!/usr/bin/env python3
"""
ToolGuard Wrapper for 邮件发送

使用 Python smtplib 直接发送邮件，通过 ToolGuard 监控
"""

import subprocess
import sys
import json
import http.client
import os
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart

TOOLGUARD_HOST = '127.0.0.1'
TOOLGUARD_PORT = 8767
TIMEOUT = 5

# QQ 邮箱配置
SMTP_SERVER = 'smtp.qq.com'
SMTP_PORT = 465
SMTP_USER = '3220628278@qq.com'
SMTP_PASS = 'iyfskbhwqiqwdedb'

def check_toolguard(to_addr, subject):
    """检查 ToolGuard 是否允许执行"""
    command = f'mail-send to:{to_addr} subject:{subject}'
    risk_level = 'high'
    reason = '发送邮件，可能发送未授权内容'
    
    try:
        conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
        conn.request('POST', '/check', json.dumps({
            'tool_name': 'mail-send',
            'action': 'send',
            'parameters': {
                'command': command,
                'to': to_addr,
                'subject': subject
            }
        }), {'Content-Type': 'application/json'})
        
        response = conn.getresponse()
        data = json.loads(response.read().decode())
        conn.close()
        
        if data.get('need_confirmation'):
            print(f"\n🛡️ ToolGuard 拦截：{command}")
            print(f"   原因：{data.get('reason', reason)}")
            print(f"   风险等级：{data.get('risk_level', risk_level)}")
            print(f"   确认 ID: {data.get('confirmation_id')}")
            print(f"\n请在 Web 界面确认：http://{TOOLGUARD_HOST}:{TOOLGUARD_PORT}")
            
            import time
            start_time = time.time()
            timeout = 300
            
            while time.time() - start_time < timeout:
                try:
                    conn = http.client.HTTPConnection(TOOLGUARD_HOST, TOOLGUARD_PORT, timeout=TIMEOUT)
                    conf_id = data.get('confirmation_id')
                    conn.request('GET', f'/api/confirmation/{conf_id}')
                    response = conn.getresponse()
                    status_data = json.loads(response.read().decode())
                    conn.close()
                    
                    status = status_data.get('status')
                    if status == 'approved':
                        print("✅ 用户已允许，继续执行...\n")
                        return True
                    elif status == 'denied':
                        print("❌ 用户已拒绝，终止执行")
                        sys.exit(1)
                    elif status == 'expired':
                        print("⏰ 确认已超时，终止执行")
                        sys.exit(1)
                except Exception:
                    pass
                time.sleep(2)
            
            print("⏰ 等待确认超时，终止执行")
            sys.exit(1)
        
        return True
        
    except Exception as e:
        print(f"⚠️ ToolGuard 检查失败：{e}，继续执行...")
        return True

def send_email(to_addr, subject, body, from_addr=None):
    """发送邮件"""
    msg = MIMEMultipart()
    msg['From'] = from_addr or SMTP_USER
    msg['To'] = to_addr
    msg['Subject'] = subject
    msg.attach(MIMEText(body, 'plain', 'utf-8'))
    
    try:
        server = smtplib.SMTP_SSL(SMTP_SERVER, SMTP_PORT)
        server.login(SMTP_USER, SMTP_PASS)
        server.send_message(msg)
        server.quit()
        return True, '发送成功'
    except Exception as e:
        return False, str(e)

def main():
    # 从 stdin 读取邮件内容
    content = sys.stdin.read()
    
    # 解析邮件头
    to_addr = None
    subject = '无主题'
    from_addr = None
    body_lines = []
    in_body = False
    
    for line in content.split('\n'):
        if in_body:
            body_lines.append(line)
        elif line.strip() == '':
            in_body = True
        elif line.lower().startswith('to:'):
            to_addr = line[3:].strip()
        elif line.lower().startswith('subject:'):
            subject = line[8:].strip()
        elif line.lower().startswith('from:'):
            from_addr = line[5:].strip()
    
    if not to_addr:
        print("❌ 错误：缺少收件人 (To:)")
        sys.exit(1)
    
    # 检查 ToolGuard
    check_toolguard(to_addr, subject)
    
    # 发送邮件
    body = '\n'.join(body_lines)
    success, msg = send_email(to_addr, subject, body, from_addr)
    
    if success:
        print(f"✅ 邮件已发送：{to_addr}")
        print(f"   主题：{subject}")
        sys.exit(0)
    else:
        print(f"❌ 发送失败：{msg}")
        sys.exit(1)

if __name__ == '__main__':
    main()
