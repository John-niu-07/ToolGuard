#!/bin/bash
# OpenClaw Safety Guard - Configuration Command Wrapper
# 用法：safety-config show|set|add ...

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/scripts/safety_config.py"

# 检查 Python 虚拟环境
if [ -f "$SCRIPT_DIR/../openclaw-safety-guard/venv/bin/activate" ]; then
    source "$SCRIPT_DIR/../openclaw-safety-guard/venv/bin/activate"
fi

# 执行 Python 脚本
python3 "$PYTHON_SCRIPT" "$@"
